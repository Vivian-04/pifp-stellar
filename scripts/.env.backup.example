# =============================================================================
# PIFP Backup System Configuration
# =============================================================================
# Copy this file to .env.backup and configure for your environment
# NEVER commit .env.backup to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Path to the SQLite database file to backup
# Default: /workspace/backend/indexer/pifp_events.db
BACKUP_DB_PATH=/workspace/backend/indexer/pifp_events.db

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
# Storage provider: 's3' or 'gcs'
STORAGE_TYPE=s3

# For AWS S3:
BACKUP_BUCKET=pifp-database-backups
BACKUP_REGION=us-east-1

# AWS Credentials (or use IAM role)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# For Google Cloud Storage (uncomment if using GCS):
# STORAGE_TYPE=gcs
# BACKUP_BUCKET=pifp-database-backups
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# -----------------------------------------------------------------------------
# Retention Policy
# -----------------------------------------------------------------------------
# Number of days to retain backups (default: 30)
BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Log file path (ensure directory exists and is writable)
LOG_FILE=/var/log/pifp_backup.log

# -----------------------------------------------------------------------------
# Backup Schedule (for cron job configuration)
# -----------------------------------------------------------------------------
# Default: Daily at 2:00 AM UTC
# Cron format: minute hour day month weekday
BACKUP_SCHEDULE="0 2 * * *"
